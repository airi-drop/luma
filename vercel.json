{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/((?!api(?:/|$)|@vite(?:/|$)|@react-refresh$|src(?:/|$)|node_modules(?:/|$)|assets(?:/|$)|icons(?:/|$)|favicon\\.svg$|manifest(?:\\.json|\\.webmanifest)$|registerSW(?:\\.js)?$|sw(?:\\.js)?$|workbox-[^/]+\\.js$|.*\\.[^/]+$).*)",
      "destination": "/index.html"
    }
  ]
}
