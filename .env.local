# Pilih provider (default: gemini). Pilihan: gemini | openai | openrouter
VITE_AI_PROVIDER=gemini

# Override model id (opsional). Default per provider:
#   gemini     → gemini-2.5-flash
#   openai     → gpt-4o-mini
#   openrouter → google/gemini-2.5-flash
VITE_AI_MODEL=gemini-2.5-flash

# API key — boleh universal atau provider-specific.
# Provider-specific lebih prioritas dari yang universal.
VITE_AI_API_KEY=

# Provider-specific keys
VITE_GEMINI_API_KEY=AIzaSyBsU-nFl-3j-LMiG0VSwwwQipkiA95U2q0
VITE_OPENAI_API_KEY=sk-...
VITE_OPENROUTER_API_KEY=sk-or-...
